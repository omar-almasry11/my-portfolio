<section class="pt-24 px-[5%] {{ sectionPaddingBottom | default: 'pb-12' }}">
  <div class="max-w-6xl mx-auto">
    <h1
      id="{{ mainTitleId | default: 'pageTitle' }}"
      class="{{ titleMarginBottom | default: 'mb-4' }} w-fit max-w-full{% unless disableColorfulHeading %} js-colorful-heading{% endunless %} {{ mainTitleClass | default: '' }}"
    >
      {{ headerTitle | default: 'Lorem ipsum' }}
    </h1>
    {% if headerSubtitle %}
      <p class="text-[1.5rem] font-light text-normalLight {{ headerSubtitleMaxWidth | default: 'max-w-2xl' }} ml-0 leading-tight dark:text-invertedLight mt-4">
        {{
          headerSubtitle
          | default: 'Anim aute id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem cupidatat commodo. Elit sunt amet fugiat veniam occaecat fugiat.'
        }}
      </p>
    {% endif %}
  </div>
</section>
