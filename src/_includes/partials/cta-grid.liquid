<section class="cta-grid-container">
  <!-- Animated Grid Background -->
  <div class="cta-grid absolute inset-0 grid grid-cols-20 grid-rows-20">
    {% for i in (1..400) %}
      <div class="cta-grid-item"></div>
    {% endfor %}
  </div>

  <!-- Content -->
  <div class="relative z-10 container mx-auto max-w-6xl">
    <div class="flex w-full flex-col gap-12 lg:flex-row lg:items-center lg:justify-between">
      <!-- Left: Title and Subtext -->
      <div class="min-w-0 lg:max-w-[58%]">
        <h2 class="text-4xl sm:text-[2.5rem] md:text-[2.75rem] font-bold mb-2.5 text-white leading-[1.1] tracking-tight">
          {{ title | default: "Let's work together" }}
        </h2>
        <p class="max-w-lg text-xl font-light sm:text-2xl text-white/90 leading-tight text-balance">
          {{ subtext | default: "I'm currently available for full-time roles and select freelance projects." }}
        </p>
      </div>

      <!-- Right: Button -->
      <div class="flex w-full shrink-0 justify-start lg:w-auto lg:justify-end">
        <a
          href="{{ buttonUrl | default: 'mailto:hello@omaralmasry.com?subject=Project%20Inquiry' }}"
          class="footer-cta-cursor-link group inline-flex items-center justify-center gap-2 rounded-md border-2 border-solid px-8 py-4 text-lg font-semibold no-underline transition-[border-color] duration-500 ease-out"
        >
          <span class="text-inherit">{{ buttonText | default: 'Send me an email' }}</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-1 sm:h-6 sm:w-6"
            viewBox="0 0 256 256"
          >
            <path d="M224,56l-96,88L32,56Z" opacity="0.2"></path>
            <path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-96,85.15L52.57,64H203.43ZM98.71,128,40,181.81V74.19Zm11.84,10.85,12,11.05a8,8,0,0,0,10.82,0l12-11.05,58,53.15H52.57ZM157.29,128,216,74.18V181.82Z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
