              </svg>
            </a>

            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/omar-al-masry-608a1581/"
              target="_blank"
              class="footer-social-link focus:outline-none focus:ring-2 focus:ring-teal-500 transition duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-7 h-7 fill-current"
                role="img"
                aria-label="LinkedIn"
                viewBox="0 0 256 256"
              >
                <path d="M216,24H40A16,16,0,0,0,24,40V216a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V40A16,16,0,0,0,216,24Zm0,192H40V40H216V216ZM96,112v64a8,8,0,0,1-16,0V112a8,8,0,0,1,16,0Zm88,28v36a8,8,0,0,1-16,0V140a20,20,0,0,0-40,0v36a8,8,0,0,1-16,0V112a8,8,0,0,1,15.79-1.78A36,36,0,0,1,184,140ZM100,84A12,12,0,1,1,88,72,12,12,0,0,1,100,84Z"></path>
              </svg>
            </a>

            <!-- Email -->
            <a
              href="mailto:hello@omaralmasry.com"
              class="footer-social-link focus:outline-none focus:ring-2 focus:ring-teal-500 transition duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-7 h-7 fill-current"
                role="img"
                aria-label="Email"
                viewBox="0 0 256 256"
              >
                <path d="M227.32,28.68a16,16,0,0,0-15.66-4.08l-.15,0L19.57,82.84a16,16,0,0,0-2.49,29.8L102,154l41.3,84.87A15.86,15.86,0,0,0,157.74,248q.69,0,1.38-.06a15.88,15.88,0,0,0,14-11.51l58.2-191.94c0-.05,0-.1,0-.15A16,16,0,0,0,227.32,28.68ZM157.83,231.85l-.05.14,0-.07-40.06-82.3,48-48a8,8,0,0,0-11.31-11.31l-48,48L24.08,98.25l-.07,0,.14,0L216,40Z"></path>
              </svg>
            </a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</footer>
