              href="https://github.com/omar-almasry11"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social-link focus:outline-none focus:ring-2 focus:ring-teal-500 transition duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-7 h-7 fill-current"
                role="img"
                aria-label="GitHub"
                viewBox="0 0 256 256"
              >
