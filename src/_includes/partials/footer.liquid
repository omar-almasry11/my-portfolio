<!-- Back to Top Button -->
<button
  id="back-to-top"
  class="fixed bottom-6 right-4 z-50 flex items-center justify-center rounded-lg bg-normal p-0 text-normal shadow-low transition-[color,box-shadow] duration-300 hover:text-lapis-light sm:bottom-7 dark:bg-inverted dark:text-inverted dark:shadow-lowInverted dark:hover:text-amber-light hidden size-12"
  aria-label="Back to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="currentColor"
    viewBox="0 0 256 256"
    class="pointer-events-none h-6 w-6 sm:h-7 sm:w-7"
  >
    <path d="M213.66,165.66a8,8,0,0,1-11.32,0L128,91.31,53.66,165.66a8,8,0,0,1-11.32-11.32l80-80a8,8,0,0,1,11.32,0l80,80A8,8,0,0,1,213.66,165.66Z"></path>
  </svg>
</button>

<footer>
  <!-- CTA Grid Section -->
  <div class="cta-grid-container">
    <!-- Animated Grid Background -->
    <div class="cta-grid absolute inset-0 grid grid-cols-20 grid-rows-20">
      {% for i in (1..400) %}
        <div class="cta-grid-item"></div>
      {% endfor %}
    </div>

    <!-- Content -->
    <div class="relative z-10 container mx-auto max-w-6xl">
      <div class="flex w-full flex-col gap-8 lg:flex-row lg:items-center lg:justify-between lg:gap-10">
        <!-- Left: Title and Subtext -->
        <div class="min-w-0 lg:max-w-[58%]">
          <h2 class="text-[2rem] font-medium mb-2 text-white leading-[1.1] tracking-tight">
            Let's work together
          </h2>
          <p class="max-w-lg text-[1.5rem] font-light text-white/90 leading-tight text-balance">
            I'm currently available for full-time roles and select freelance projects.
          </p>
        </div>

        <!-- Right: Button -->
        <div class="flex w-full shrink-0 justify-start lg:w-auto lg:justify-end">
          <a
            href="mailto:hello@omaralmasry.com?subject=Project%20Inquiry"
            class="footer-cta-cursor-link group inline-flex min-w-0 max-w-full flex-wrap items-center justify-center gap-2 rounded-md border-2 border-solid px-6 py-3 text-left font-semibold no-underline transition-[border-color] duration-500 ease-out"
          >
            <span class="min-w-0 break-words text-inherit">Send me an email</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
              class="h-4 w-4 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-1 sm:h-6 sm:w-6"
              viewBox="0 0 256 256"
            >
              <path d="M227.32,28.68a16,16,0,0,0-15.66-4.08l-.15,0L19.57,82.84a16,16,0,0,0-2.49,29.8L102,154l41.3,84.87A15.86,15.86,0,0,0,157.74,248q.69,0,1.38-.06a15.88,15.88,0,0,0,14-11.51l58.2-191.94c0-.05,0-.1,0-.15A16,16,0,0,0,227.32,28.68ZM157.83,231.85l-.05.14,0-.07-40.06-82.3,48-48a8,8,0,0,0-11.31-11.31l-48,48L24.08,98.25l-.07,0,.14,0L216,40Z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Bar -->
  <div class="border-t border-normal bg-normal pt-8 pb-16 px-[5%] text-normal dark:border-inverted dark:bg-oxford dark:pb-12 dark:text-inverted">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col items-center gap-6 md:flex-row md:items-center md:gap-4 lg:gap-8">
        <!-- Logo -->
        <div class="flex w-full shrink-0 justify-center md:flex-1 md:justify-start">
          <a href="{{ '/' | url }}" class="logo logo-nav flex shrink-0 items-center font-bold no-underline group">
            <span class="logo-morph text-xl sm:text-2xl text-normalLight transition-colors duration-300 group-hover:text-lapis-light dark:text-invertedLight dark:group-hover:text-amber-light"
              ><span class="logo-letter-o">O</span
              ><span class="logo-rest-clip"><span class="logo-rest">mar Almasry</span></span
              ><span class="logo-dot text-primary dark:text-primaryInverted">.</span></span
            >
          </a>
        </div>

        <!-- Copyright -->
        <div class="flex w-full min-w-0 justify-center md:flex-1 md:px-2">
          <p class="mb-0 text-center text-xs text-normalLight opacity-90 dark:text-inverted">
            © {% currentYear %} Omar Almasry. All rights reserved.
          </p>
        </div>

        <!-- Social Icons -->
        <div class="flex w-full shrink-0 justify-center md:flex-1 md:justify-end">
          <nav class="flex space-x-4 text-primary focus:outline-none focus:ring-2 focus:ring-teal-500 dark:text-inverted">
            <!-- GitHub -->
