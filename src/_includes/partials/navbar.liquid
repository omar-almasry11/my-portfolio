<nav id="mainNav" class="px-[5%] py-4 sticky top-0 z-50 transition-transform duration-300">
  <div class="max-w-6xl mx-auto flex w-full items-center justify-between gap-3">
    <!-- Logo -->
    <a href="{{ '/' | url }}" class="logo logo-nav flex shrink-0 items-center font-bold no-underline group" aria-label="Omar Almasry, home">
      <span class="logo-morph text-xl sm:text-2xl text-normalLight dark:text-invertedLight group-hover:text-lapis-light dark:group-hover:text-amber-light transition-colors duration-300"
        ><span class="logo-letter-o">O</span
        ><span class="logo-rest-clip"><span class="logo-rest">mar Almasry</span></span
        ><span class="logo-dot text-primary dark:text-primaryInverted">.</span></span
      >
    </a>

    <!-- About, Contact, theme toggle: single row on mobile -->
    <div class="flex min-w-0 items-center justify-end gap-2.5 sm:gap-7 md:gap-8">
      <a
        href="{{ '/about/' | url }}"
        class="menu_link shrink-0 min-h-[44px] flex items-center text-normalLight text-base sm:text-lg font-medium hover:text-inverted no-underline dark:text-invertedLight dark:hover:text-inverted"
        {% if page.url == '/about/' %}
          aria-current="page"
        {% endif %}
      >
        <span class="roll-text">
          <span data-text="About">About</span>
          <span data-text="About" aria-hidden="true">About</span>
        </span>
      </a>

      <div class="flex shrink-0 items-center gap-4 sm:gap-7 md:gap-8">
