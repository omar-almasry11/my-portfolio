---
layout: "/layouts/layout.liquid"
---
<header class="pt-24 pb-4 px-[5%] mx-auto">
  <div class="container mx-auto max-w-4xl min-w-0">
    <div class="mb-12">
      {% if categories and categories.size > 0 %}
        <ul class="flex flex-wrap gap-2 mb-6" role="list" aria-label="Post categories">
          {% for cat in categories %}
            <li>
              <span class="case-study-tag">{{ cat }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
      <h1 class="font-medium tracking-tight sm:text-6xl md:text-6xl lg:text-7xl leading-[1.1] mb-3 text-normal dark:text-inverted">
        {{ title }}
      </h1>
      {% if description %}
        <p class="text-[1.5rem] font-light text-normalLight dark:text-invertedLight leading-tight mb-4 max-w-2xl">
          {{ description }}
        </p>
      {% endif %}

      <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between border-t border-normal dark:border-inverted pt-5 mt-6">
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-base text-normalLight dark:text-invertedLight">
          <span>{{ date | date: '%B %d, %Y' }}</span>
          <span aria-hidden="true">·</span>
          <span><span id="reading-time">2</span> min read</span>
        </div>

        {% assign post_share_url = page_url | default: 'https://omaralmasry.com' | append: page.url %}
        <div class="flex flex-wrap items-center gap-5 sm:gap-4">
          <a
            href="https://twitter.com/intent/tweet?url={{ post_share_url | uri_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="case-study-next-link group relative inline-flex items-center gap-2.5 rounded-md border-0 bg-transparent px-3.5 py-2.5 text-base font-medium text-primary no-underline transition-colors duration-300 hover:text-white sm:gap-2 sm:px-3 sm:py-2 dark:text-primaryInverted dark:hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-0.5 sm:h-6 sm:w-6" viewBox="0 0 256 256" aria-hidden="true"><path d="M208,216H160L48,40H96Z" opacity="0.2"></path><path d="M214.75,211.71l-62.6-98.38,61.77-67.95a8,8,0,0,0-11.84-10.76L143.24,99.34,102.75,35.71A8,8,0,0,0,96,32H48a8,8,0,0,0-6.75,12.3l62.6,98.37-61.77,68a8,8,0,1,0,11.84,10.76l58.84-64.72,40.49,63.63A8,8,0,0,0,160,224h48a8,8,0,0,0,6.75-12.29ZM164.39,208,62.57,48h29L193.43,208Z"></path></svg>
            <span class="hidden sm:inline">Share on X</span>
          </a>

          <a
            href="https://www.linkedin.com/sharing/share-offsite/?url={{ post_share_url | uri_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="case-study-next-link group relative inline-flex items-center gap-2.5 rounded-md border-0 bg-transparent px-3.5 py-2.5 text-base font-medium text-primary no-underline transition-colors duration-300 hover:text-white sm:gap-2 sm:px-3 sm:py-2 dark:text-primaryInverted dark:hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-0.5 sm:h-6 sm:w-6" viewBox="0 0 256 256" aria-hidden="true"><path d="M224,40V216a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V40a8,8,0,0,1,8-8H216A8,8,0,0,1,224,40Z" opacity="0.2"></path><path d="M216,24H40A16,16,0,0,0,24,40V216a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V40A16,16,0,0,0,216,24Zm0,192H40V40H216V216ZM96,112v64a8,8,0,0,1-16,0V112a8,8,0,0,1,16,0Zm88,28v36a8,8,0,0,1-16,0V140a20,20,0,0,0-40,0v36a8,8,0,0,1-16,0V112a8,8,0,0,1,15.79-1.78A36,36,0,0,1,184,140ZM100,84A12,12,0,1,1,88,72,12,12,0,0,1,100,84Z"></path></svg>
            <span class="hidden sm:inline">Share on LinkedIn</span>
          </a>

          <button
            type="button"
            id="copy-post-link-btn"
            onclick="copyPostLink()"
            aria-label="Copy link to this post"
            class="case-study-next-link group relative inline-flex cursor-pointer items-center gap-2.5 rounded-md border-0 bg-transparent px-3.5 py-2.5 text-base font-medium text-primary transition-colors duration-300 hover:text-white sm:gap-2 sm:px-3 sm:py-2 dark:text-primaryInverted dark:hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-0.5 sm:h-6 sm:w-6" viewBox="0 0 256 256" aria-hidden="true"><path d="M218.34,119.6,183.6,154.34a46.58,46.58,0,0,1-44.31,12.26c-.31.34-.62.67-.95,1L103.6,202.34A46.63,46.63,0,1,1,37.66,136.4L72.4,101.66A46.6,46.6,0,0,1,116.71,89.4c.31-.34.62-.67,1-1L152.4,53.66a46.63,46.63,0,0,1,65.94,65.94Z" opacity="0.2"></path><path d="M240,88.23a54.43,54.43,0,0,1-16,37L189.25,160a54.27,54.27,0,0,1-38.63,16h-.05A54.63,54.63,0,0,1,96,119.84a8,8,0,0,1,16,.45A38.62,38.62,0,0,0,150.58,160h0a38.39,38.39,0,0,0,27.31-11.31l34.75-34.75a38.63,38.63,0,0,0-54.63-54.63l-11,11A8,8,0,0,1,135.7,59l11-11A54.65,54.65,0,0,1,224,48,54.86,54.86,0,0,1,240,88.23ZM109,185.66l-11,11A38.41,38.41,0,0,1,70.6,208h0a38.63,38.63,0,0,1-27.29-65.94L78,107.31A38.63,38.63,0,0,1,144,135.71a8,8,0,0,0,7.78,8.22H152a8,8,0,0,0,8-7.78A54.86,54.86,0,0,0,144,96a54.65,54.65,0,0,0-77.27,0L32,130.75A54.62,54.62,0,0,0,70.56,224h0a54.28,54.28,0,0,0,38.64-16l11-11A8,8,0,0,0,109,185.66Z"></path></svg>
            <span id="copy-link-text-short" class="inline sm:hidden" aria-hidden="true">Copy</span>
            <span id="copy-link-text" class="hidden sm:inline">Copy link</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<section class="pt-4 pb-24 px-[5%]">
  <div class="container mx-auto max-w-6xl min-w-0">
    <article class="prose case-study-prose mx-auto max-w-4xl">
      {{ content }}
    </article>

    {% assign prev_p = collections.posts | previousPost: page.url %}
    {% assign next_p = collections.posts | nextPost: page.url %}
    {% if prev_p or next_p %}
      <nav
        class="mt-16 flex min-w-0 w-full flex-col gap-6 border-t border-normal pt-12 dark:border-inverted {% if prev_p and next_p %}sm:flex-row sm:items-start sm:justify-between{% elsif next_p %}sm:flex-row sm:justify-end{% else %}sm:flex-row sm:justify-start{% endif %}"
        aria-label="Adjacent posts"
      >
        {% if prev_p %}
          <a
            href="{{ prev_p.url | url }}"
            class="case-study-prev-link group relative inline-flex min-w-0 max-w-full flex-wrap items-center justify-start gap-2 rounded-md px-6 py-3 text-left text-primary dark:text-primaryInverted font-medium no-underline hover:text-white dark:hover:text-white transition-colors duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 shrink-0 fill-current transition-transform duration-200 group-hover:-translate-x-1 sm:w-6 sm:h-6"
              viewBox="0 0 256 256"
              aria-hidden="true"
            >
              <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z" transform="rotate(180 128 128)"></path>
            </svg>
            <span class="min-w-0 break-words">Previous: {{ prev_p.data.title }}</span>
          </a>
        {% endif %}
        {% if next_p %}
          <a
            href="{{ next_p.url | url }}"
            class="case-study-next-link group relative inline-flex min-w-0 max-w-full flex-wrap items-center justify-end gap-2 rounded-md px-6 py-3 text-left text-primary dark:text-primaryInverted font-medium no-underline hover:text-white dark:hover:text-white transition-colors duration-300"
          >
            <span class="min-w-0 break-words">Next: {{ next_p.data.title }}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-1 sm:w-6 sm:h-6"
              viewBox="0 0 256 256"
              aria-hidden="true"
            >
              <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path>
            </svg>
          </a>
        {% endif %}
      </nav>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('reading-time');
    if (el) {
      const words = document.querySelector('article').innerText.trim().split(/\s+/).length;
      el.textContent = Math.max(1, Math.round(words / 200));
    }
  });

  function copyPostLink() {
    const url = window.location.href;
    const longEl = document.getElementById('copy-link-text');
    const shortEl = document.getElementById('copy-link-text-short');
    const btn = document.getElementById('copy-post-link-btn');

    const applyFeedback = () => {
      if (longEl) longEl.textContent = 'Copied!';
      if (shortEl) shortEl.textContent = 'Done';
      if (btn) btn.setAttribute('aria-label', 'Link copied to clipboard');
      window.setTimeout(() => {
        if (longEl) longEl.textContent = 'Copy link';
        if (shortEl) shortEl.textContent = 'Copy';
        if (btn) btn.setAttribute('aria-label', 'Copy link to this post');
      }, 2000);
    };

    const fallbackCopy = () => {
      try {
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.readOnly = true;
        ta.setAttribute('aria-hidden', 'true');
        ta.style.position = 'fixed';
        ta.style.top = '0';
        ta.style.left = '0';
        ta.style.opacity = '0';
        ta.style.pointerEvents = 'none';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        ta.setSelectionRange(0, url.length);
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        return ok;
      } catch (e) {
        return false;
      }
    };

    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(url).then(applyFeedback).catch(() => {
        if (fallbackCopy()) applyFeedback();
      });
      return;
    }
    if (fallbackCopy()) applyFeedback();
  }
  window.copyPostLink = copyPostLink;
</script>
