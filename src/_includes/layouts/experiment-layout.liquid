---
layout: "/layouts/layout.liquid"
---
<header class="pt-24 pb-4 px-[5%] mx-auto">
  <div class="container mx-auto max-w-4xl min-w-0">
    <div class="mb-12">
      {% if categories and categories.size > 0 %}
        <ul class="flex flex-wrap gap-2 mb-6" role="list" aria-label="Experiment tags">
          {% for cat in categories %}
            <li>
              <span class="case-study-tag">{{ cat }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
      <h1 class="font-medium tracking-tight sm:text-6xl md:text-6xl lg:text-7xl leading-[1.1] mb-3 text-normal dark:text-inverted">
        {{ title }}
      </h1>
      {% if header_subtitle %}
        <p class="text-[1.5rem] font-light text-normalLight dark:text-invertedLight leading-tight mb-4 max-w-2xl">
          {{ header_subtitle }}
        </p>
      {% endif %}
      {% if header-overview %}
        <p class="text-[1.125rem] text-normalLight font-light dark:text-invertedLight max-w-[40rem] leading-relaxed mb-0">
          {{ header-overview }}
        </p>
      {% endif %}
    </div>
  </div>
</header>
<section class="pt-4 pb-24 px-[5%]">
  <div class="container mx-auto max-w-6xl min-w-0">
    <article class="prose case-study-prose mx-auto max-w-4xl">
      {{ content }}
    </article>

    {% assign prev_x = collections.experiments | previousExperiment: page.url %}
    {% assign next_x = collections.experiments | nextExperiment: page.url %}
    {% if prev_x or next_x %}
      <nav
        class="mt-16 flex min-w-0 w-full flex-col gap-6 border-t border-normal pt-12 dark:border-inverted {% if prev_x and next_x %}sm:flex-row sm:items-start sm:justify-between{% elsif next_x %}sm:flex-row sm:justify-end{% else %}sm:flex-row sm:justify-start{% endif %}"
        aria-label="Adjacent experiments"
      >
        {% if prev_x %}
          <a
            href="{{ prev_x.url | url }}"
            class="case-study-prev-link group relative inline-flex min-w-0 max-w-full flex-wrap items-center justify-start gap-2 rounded-md px-6 py-3 text-left text-primary dark:text-primaryInverted font-medium no-underline hover:text-white dark:hover:text-white transition-colors duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 shrink-0 fill-current transition-transform duration-200 group-hover:-translate-x-1 sm:w-6 sm:h-6"
              viewBox="0 0 256 256"
              aria-hidden="true"
            >
              <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z" transform="rotate(180 128 128)"></path>
            </svg>
            <span class="min-w-0 break-words">Previous Experiment: {{ prev_x.data.title }}</span>
          </a>
        {% endif %}
        {% if next_x %}
          <a
            href="{{ next_x.url | url }}"
            class="case-study-next-link group relative inline-flex min-w-0 max-w-full flex-wrap items-center justify-end gap-2 rounded-md px-6 py-3 text-left text-primary dark:text-primaryInverted font-medium no-underline hover:text-white dark:hover:text-white transition-colors duration-300"
          >
            <span class="min-w-0 break-words">Next Experiment: {{ next_x.data.title }}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4 shrink-0 fill-current transition-transform duration-200 group-hover:translate-x-1 sm:w-6 sm:h-6"
              viewBox="0 0 256 256"
              aria-hidden="true"
            >
              <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path>
            </svg>
          </a>
        {% endif %}
      </nav>
    {% endif %}
  </div>
</section>

{% if requireThree %}
  <script defer src="https://cdn.jsdelivr.net/npm/three@0.147.0/build/three.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/three@0.147.0/examples/js/loaders/RGBELoader.js"></script>
{% endif %}
{% if scripts %}
  {% for src in scripts %}
    <script defer src="{{ src }}"></script>
  {% endfor %}
{% endif %}
