<!doctype html>
<html lang="en">
  <head>
    <!-- Basic Meta Tags -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta
      name="description"
      content="{{ description | default: 'Digital designer specializing in Webflow, accessibility, and performance optimization. Building scalable websites for enterprise clients and agencies.' }}"
    >
    <meta name="author" content="Omar Almasry">
    <title>{{ title | default: 'Omar Almasry | Digital Designer & Webflow Specialist' }}</title>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link
      rel="preload"
      href="/fonts/AtkinsonHyperlegibleNext-VariableFont_wght.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    >

    <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.css">
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.css"
      media="print"
      onload="this.media='all'"
    >
    <noscript>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.css">
    </noscript>

    <!-- Dynamic Favicon managed via /scripts/dynamic-favicon.js -->
    <script src="/scripts/dynamic-favicon.js" defer></script>
    <link rel="manifest" href="/site.webmanifest">

    <!-- Social Media Meta Tags -->
    <meta property="og:title" content="{{ title | default: 'Omar Almasry | Digital Designer & Webflow Specialist' }}">
    <meta
      property="og:description"
      content="{{ description | default: 'Digital designer specializing in Webflow, accessibility, and performance optimization. Building scalable websites for enterprise clients and agencies.' }}"
    >
    <meta property="og:image" content="{{ og_image | default: '/images/png/og.png' }}">
    <meta property="og:url" content="{{ page_url | default: 'https://omaralmasry.com' }}{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Omar Almasry - Digital Designer">
    <meta property="og:locale" content="en_US">
    <link rel="canonical" href="{{ page_url | default: 'https://omaralmasry.com' }}{{ page.url }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title | default: 'Omar Almasry | Digital Designer & Webflow Specialist' }}">
    <meta
      name="twitter:description"
      content="{{ description | default: 'Digital designer specializing in Webflow, accessibility, and performance optimization. Building scalable websites for enterprise clients and agencies.' }}"
    >
    <meta name="twitter:image" content="{{ og_image | default: '/images/png/og.png' }}">

    <!-- Robots Meta -->
    <meta name="robots" content="index, follow">

    <!-- Stylesheet -->
    <link href="/dist/output.css" rel="stylesheet">
    <noscript>
      <style>
        .load_grid {
          display: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <div class="load_grid"></div>
    <script>
      (function () {
        const colors = ['#C48A1E', '#8A9BB5', '#4A5C8A', '#2A4494'];
        const loadGrid = document.querySelector('.load_grid');

        // Square size: base minDim/10 (2× vs original /20), then ×1.5 for 50% larger cells
        const squareSize = (Math.min(window.innerWidth, window.innerHeight) / 10) * 1.5;
        const cols = Math.ceil(window.innerWidth / squareSize);
        const rows = Math.ceil(window.innerHeight / squareSize);
        const totalItems = cols * rows;

        // Update CSS grid template
        loadGrid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        loadGrid.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
        loadGrid.dataset.gridCols = String(cols);

        // Batch DOM insertions with a DocumentFragment to minimize reflows
        const fragment = document.createDocumentFragment();
        const itemElements = [];
        const storedColors = sessionStorage.getItem('transitionColors');
        let cachedColors = null;

        if (storedColors) {
          try {
            const parsed = JSON.parse(storedColors);
            if (Array.isArray(parsed) && parsed.length === totalItems) {
              cachedColors = parsed;
            }
          } catch (err) {
            /* regenerate */
          }
        }

        // Generate items and apply colors in a single pass
        const newColors = cachedColors || [];
        for (let i = 0; i < totalItems; i++) {
          const item = document.createElement('div');
          item.className = 'load_grid-item';

          if (cachedColors) {
            item.style.backgroundColor = cachedColors[i];
          } else {
            let color;
            let attempts = 0;
            const row = Math.floor(i / cols);
            const col = i % cols;
            do {
              color = colors[Math.floor(Math.random() * colors.length)];
              attempts++;
              const leftColor = col > 0 ? newColors[i - 1] : null;
              const topColor = row > 0 ? newColors[i - cols] : null;
              if (color !== leftColor && color !== topColor) break;
            } while (attempts < 10);
            item.style.backgroundColor = color;
            newColors.push(color);
          }

          fragment.appendChild(item);
        }

        if (!cachedColors) {
          sessionStorage.setItem('transitionColors', JSON.stringify(newColors));
        }

        loadGrid.appendChild(fragment);
      })();
    </script>
    {% render 'partials/navbar', page: page %}
    <main>
      {{ content }}
    </main>
    {% render 'partials/footer' %}

    <!-- Custom Cursor -->
    <div class="cursor-wrapper">
      <div class="cursor">
        <div class="cursor_dot"></div>
      </div>
    </div>

    <!-- JavaScript -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
    <script src="/scripts/main.js" defer></script>
    <script src="/scripts/cursor.js" defer></script>
    <script src="/scripts/page-transition.js" defer></script>
    <script src="/scripts/cta-grid-animation.js" defer></script>
    {% if page.url == '/' or page.url == '/about/' %}
      <script src="/scripts/hero-cell-pixel-scroll.js" defer></script>
    {% endif %}
    {% if page.url == '/' %}
      <script src="/scripts/color-block-fill.js" defer></script>
      <script src="/scripts/case-study-card-pixel-hover.js" defer></script>
    {% endif %}
    {% if page.url == '/about/' %}
      <script src="/scripts/about-card-pixel-fill.js" defer></script>
    {% endif %}
    {% if page.url == '/blog/' or page.url == '/services/' or page.url == '/case-studies/' %}
      <script src="/scripts/colorful-heading.js" defer></script>
    {% endif %}
  </body>
</html>
